{
  "name": "pi-fusion",
  "version": "0.1.0",
  "description": "Standalone LLM Fusion extension for pi: parallel read-only planners, then one actor turn.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "llm-fusion"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "tsx scripts/smoke.ts",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm test && pnpm run smoke"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-fusion/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leblancfg/pi-fusion.git"
  },
  "bugs": {
    "url": "https://github.com/leblancfg/pi-fusion/issues"
  },
  "homepage": "https://github.com/leblancfg/pi-fusion#readme"
}
